# Public URL of this gateway (no trailing slash)
BASE_URL=https://ac-mcp.fly.dev

# PostgreSQL connection string (set automatically by fly postgres attach)
DATABASE_URL=postgres://user:password@host:5432/dbname

# AES-256-GCM encryption key (32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Server port (default: 3000)
PORT=3000
